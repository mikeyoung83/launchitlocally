---
import MainLayout from "../layouts/MainLayout.astro";
import { Image } from "astro:assets";
import performance_1 from "../assets/performance_1.jpg";
---

<MainLayout title="Creative Digital Agency | Home">
    <div class="relative isolate overflow-hidden">
        <div
            class="mx-auto max-w-7xl px-6 pt-10 pb-24 sm:pb-32 lg:flex lg:px-8 lg:py-40"
        >
            <div class="mx-auto max-w-2xl lg:mx-0 lg:shrink-0 lg:pt-8">
                <div class="mt-12 sm:mt-32 lg:mt-16">
                    <span
                        class="rounded-full bg-secondary/10 px-3 py-1 text-sm/6 font-semibold text-primary"
                        >Custom Designs, Custom Coded
                    </span>
                </div>
                <h1
                    class="mt-10 mb-4 text-5xl font-semibold tracking-tight text-pretty sm:text-7xl"
                >
                    Your Business
                    <span class="text-primary">Deserves Better</span>
                    Than a Template.
                </h1>
                <p class="mb-4 text-sm text-pretty sm:text-xl/8">
                    We build custom, <strong>high-performing websites</strong> from
                    the ground up—no AI shortcuts, no slow WordPress plugins.
                </p>

                <h2 class="text-2xl font-bold tracking-tighter">
                    Just <span class="text-accent">pure speed</span> and professional
                    results.
                </h2>

                <div class="mt-10 flex items-center gap-x-6">
                    <a href="/contact" class="btn btn-primary text-white"
                        >Get Started</a
                    >
                    <a href="services" class="text-sm/6 font-semibold"
                        >Learn more <span aria-hidden="true">→</span></a
                    >
                </div>
            </div>
            <div
                class="mx-auto mt-16 flex max-w-2xl sm:mt-24 lg:mt-0 lg:mr-0 lg:ml-10 lg:max-w-none lg:flex-none xl:ml-32"
            >
                <div class="max-w-3xl flex-none sm:max-w-5xl lg:max-w-none">
                    <div
                        class="-m-2 rounded-xl bg-gray-900/5 p-2 ring-1 ring-gray-900/10 ring-inset lg:-m-4 lg:rounded-2xl lg:p-4"
                    >
                        <img
                            src="https://tailwindui.com/plus-assets/img/component-images/project-app-screenshot.png"
                            alt="App screenshot"
                            width="2432"
                            height="1442"
                            class="w-[76rem] rounded-md ring-1 shadow-2xl ring-gray-900/10"
                        />
                    </div>
                </div>
            </div>
        </div>
    </div>

    <section class="bg-secondary/10 py-24 sm:py-32">
        <div class="mx-auto max-w-7xl px-6 lg:px-8">
            <div class="mx-auto max-w-3xl lg:text-center">
                <span
                    class="rounded-full bg-secondary/10 px-3 py-1 text-sm/6 font-semibold text-primary"
                    >What We Do
                </span>
                <h2
                    class="mt-6 text-4xl font-semibold tracking-tight text-pretty sm:text-5xl lg:text-balance"
                >
                    You Run Your Business. <br />We’ll Run Your Web Presence.
                </h2>
                <p class="mt-6 text-xl/8">
                    Stop wasting your weekends fighting with broken plugins and
                    slow templates. <br />When you partner with LaunchItLocally,
                    your website becomes our priority. We handle the technical
                    heavy lifting—from hand-coding your interface to ensuring
                    your security is ironclad. You get a <b
                        >professional digital foundation</b
                    > that stays updated, stays fast, and stays online, so you can
                    focus on what you do best: serving your customers.
                </p>
            </div>
            <div
                class="mx-auto mt-16 max-w-2xl sm:mt-20 lg:mt-24 lg:max-w-none"
            >
                <dl
                    class="grid max-w-xl grid-cols-1 gap-x-8 gap-y-16 lg:max-w-none lg:grid-cols-3"
                >
                    <div class="flex flex-col">
                        <dt
                            class="flex items-center gap-x-3 text-base/7 font-semibold text-accent"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke-width="1.5"
                                stroke="currentColor"
                                class="size-6"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M10.5 1.5H8.25A2.25 2.25 0 0 0 6 3.75v16.5a2.25 2.25 0 0 0 2.25 2.25h7.5A2.25 2.25 0 0 0 18 20.25V3.75a2.25 2.25 0 0 0-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3"
                                ></path>
                            </svg>

                            Mobile First
                        </dt>
                        <dd class="mt-4 flex flex-auto flex-col text-base/7">
                            <p class="flex-auto">
                                In {new Date().getFullYear()}, your "front door"
                                is a smartphone screen. We build for the thumb
                                first, ensuring your site feels like a native
                                app. No awkward zooming—just a seamless
                                experience that converts.
                            </p>
                            <p class="mt-6">
                                <a
                                    href="#"
                                    class="text-sm/6 font-semibold text-primary"
                                    >Learn more <span aria-hidden="true">→</span
                                    ></a
                                >
                            </p>
                        </dd>
                    </div>
                    <div class="flex flex-col">
                        <dt
                            class="flex items-center gap-x-3 text-base/7 font-semibold text-accent"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke-width="1.5"
                                stroke="currentColor"
                                class="size-6"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M9 17.25v1.007a3 3 0 0 1-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0 1 15 18.257V17.25m6-12V15a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 15V5.25m18 0A2.25 2.25 0 0 0 18.75 3H5.25A2.25 2.25 0 0 0 3 5.25m18 0V12a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 12V5.25"
                                ></path>
                            </svg>

                            Fully Responsize
                        </dt>
                        <dd class="mt-4 flex flex-auto flex-col text-base/7">
                            <p class="flex-auto">
                                Whether your customers use a 5-inch phone or a
                                32-inch monitor, your brand will look flawless.
                                Our custom layouts adapt fluidly to any screen
                                size, preserving your professional image
                                everywhere.
                            </p>
                            <p class="mt-6">
                                <a
                                    href="#"
                                    class="text-sm/6 font-semibold text-primary"
                                    >Learn more <span aria-hidden="true">→</span
                                    ></a
                                >
                            </p>
                        </dd>
                    </div>
                    <div class="flex flex-col">
                        <dt
                            class="flex items-center gap-x-3 text-base/7 font-semibold text-accent"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke-width="1.5"
                                stroke="currentColor"
                                class="size-6"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="m3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z"
                                ></path>
                            </svg>

                            Optimized Page Speed
                        </dt>
                        <dd class="mt-4 flex flex-auto flex-col text-base/7">
                            <p class="flex-auto">
                                Speed is an SEO requirement, not a luxury. We
                                obsess over every kilobyte to deliver
                                near-instant load times, helping you rank higher
                                on Google and providing the best possible user
                                experience.
                            </p>
                            <p class="mt-6">
                                <a
                                    href="#"
                                    class="text-sm/6 font-semibold text-primary"
                                    >Learn more <span aria-hidden="true">→</span
                                    ></a
                                >
                            </p>
                        </dd>
                    </div>
                </dl>
            </div>
        </div>
    </section>

    <section class="overflow-hidden py-24 sm:py-32">
        <div class="mx-auto max-w-2xl px-6 lg:max-w-7xl lg:px-8">
            <div class="max-w-4xl">
                <span
                    class="rounded-full bg-secondary/10 px-3 py-1 text-sm/6 font-semibold text-primary"
                    >Performance
                </span>
                <h2
                    class="mt-6 text-4xl font-semibold tracking-tight text-pretty sm:text-5xl"
                >
                    Speed is a Business Strategy, Not a Technical Detail.
                </h2>
                <p class="mt-6 text-xl/8 text-balance">
                    In {new Date().getFullYear()}, your customers aren't just
                    looking for information—they’re looking for it now. Google
                    has made it clear: <b>speed is a primary ranking factor</b> for
                    local search. If your site takes more than three seconds to load,
                    half of your visitors have already clicked away to a competitor.
                </p>
            </div>
            <section
                class="mt-20 grid grid-cols-1 lg:grid-cols-2 lg:gap-x-8 lg:gap-y-16"
            >
                <div class="lg:pr-8">
                    <p class="text-base/7">
                        <b class="text-accent block">Higher Google Rankings:</b> Faster
                        sites get indexed more effectively and ranked higher in local
                        search results. If you aren't fast, you're invisible.
                    </p>

                    <p class="mt-6 text-base/7">
                        <b class="text-accent block">Lower Bounce Rates:</b> Every
                        millisecond saved is a customer saved. Fast load times keep
                        users on your page and focused on your services.
                    </p>

                    <p class="mt-6 text-base/7">
                        <b class="text-accent block">Increased Conversion:</b> Research
                        shows that a 1-second improvement in mobile load times can
                        increase conversion rates by up to 20%.
                    </p>

                    <p class="mt-6 text-base/7">
                        <b class="text-accent block">Long-Term Reliability:</b> Our
                        custom-coded approach means your site won't "slow down" over
                        time like a WordPress site weighed down by old plugins.
                    </p>

                    <p class="mt-8 text-xl/8 text-balance">
                        <b>We don’t just build "pretty" websites.</b>
                        <br /> We build high-velocity assets designed to capture leads
                        before they lose interest. By stripping away the bloat of
                        traditional platforms,your website is the fastest in your
                        neighborhood.
                    </p>
                </div>
                <div class="pt-16 lg:row-span-2 lg:-mr-16 xl:mr-auto">
                    <div
                        class="-mx-8 grid grid-cols-2 gap-4 sm:-mx-16 sm:grid-cols-4 lg:mx-0 lg:grid-cols-2 lg:gap-4 xl:gap-8"
                    >
                        <div
                            class="aspect-square overflow-hidden rounded-xl shadow-xl outline-1 -outline-offset-1 outline-black/10"
                        >
                            <Image
                                loading="lazy"
                                src={performance_1}
                                alt="Man reviewing performance results."
                            />
                        </div>
                        <div
                            class="-mt-8 aspect-square overflow-hidden rounded-xl shadow-xl outline-1 -outline-offset-1 outline-black/10 lg:-mt-40"
                        >
                            <img
                                alt=""
                                src="https://images.unsplash.com/photo-1557804506-669a67965ba0?&auto=format&fit=crop&crop=left&w=560&h=560&q=90"
                                class="block size-full object-cover"
                            />
                        </div>
                        <div
                            class="aspect-square overflow-hidden rounded-xl shadow-xl outline-1 -outline-offset-1 outline-black/10"
                        >
                            <img
                                alt=""
                                src="https://images.unsplash.com/photo-1559136555-9303baea8ebd?&auto=format&fit=crop&crop=left&w=560&h=560&q=90"
                                class="block size-full object-cover"
                            />
                        </div>
                        <div
                            class="-mt-8 aspect-square overflow-hidden rounded-xl shadow-xl outline-1 -outline-offset-1 outline-black/10 lg:-mt-40"
                        >
                            <img
                                alt=""
                                src="https://images.unsplash.com/photo-1598257006458-087169a1f08d?&auto=format&fit=crop&crop=center&w=560&h=560&q=90"
                                class="block size-full object-cover"
                            />
                        </div>
                    </div>
                </div>
                <div class="max-lg:mt-16 lg:col-span-1">
                    <hr class="mt-6 border-t border-gray-200" />
                    <dl
                        class="mt-6 grid grid-cols-1 gap-x-8 gap-y-4 sm:grid-cols-2"
                    >
                        <div
                            class="flex flex-col gap-y-2 max-sm:border-b max-sm:border-dotted max-sm:border-gray-200 max-sm:pb-4"
                        >
                            <dt class="text-sm/6">Google Page Speed Score</dt>
                            <dd
                                class="order-first text-6xl font-semibold tracking-tight"
                            >
                                <span>100</span>
                            </dd>
                        </div>
                        <div class="flex flex-col gap-y-2">
                            <dt class="text-sm/6">Satisfaction Guaranteed</dt>
                            <dd
                                class="order-first text-6xl font-semibold tracking-tight"
                            >
                                <span>100</span>%
                            </dd>
                        </div>
                    </dl>
                </div>
            </section>
        </div>
    </section>

    <section
        class="relative bg-secondary/10 isolate px-6 py-24 sm:py-32 lg:px-8"
    >
        <div
            class="absolute inset-x-0 -top-3 -z-10 transform-gpu overflow-hidden px-36 blur-3xl"
            aria-hidden="true"
        >
        </div>
        <div class="mx-auto max-w-4xl text-center">
            <span
                class="rounded-full bg-secondary/10 px-3 py-1 text-sm/6 font-semibold text-primary"
                >Pricing
            </span>
            <h2
                class="mt-6 text-4xl font-semibold tracking-tight text-pretty sm:text-5xl"
            >
                Choose The Right Plan For You
            </h2>
        </div>
        <p
            class="mx-auto mt-6 max-w-2xl text-center text-lg font-medium text-pretty sm:text-xl/8"
        >
            Choose an affordable plan that’s packed with the best features for
            engaging your audience, creating customer loyalty, and driving
            sales.
        </p>
        <div
            class="mx-auto mt-16 grid max-w-lg grid-cols-1 items-center gap-y-6 sm:mt-20 sm:gap-y-0 lg:max-w-4xl lg:grid-cols-2"
        >
            <div
                class="rounded-3xl rounded-t-3xl bg-base-100 p-8 ring-1 ring-gray-900/10 sm:mx-8 sm:rounded-b-none sm:p-10 lg:mx-0 lg:rounded-tr-none lg:rounded-bl-3xl"
            >
                <h3 id="tier-hobby" class="font-semibold">Lump Sum</h3>
                <p class="mt-4 flex items-baseline gap-x-2">
                    <span class="text-5xl font-semibold tracking-tight"
                        >$4,500</span
                    >
                    <span class="text-base">+$25/month for Hosting</span>
                </p>
                <p class="mt-6">
                    The perfect plan if you&#039;re just getting started with
                    our product.
                </p>
                <ul role="list" class="mt-8 space-y-3 text-sm/6 sm:mt-10">
                    <li class="flex gap-x-3">
                        <svg
                            class="h-6 w-5 flex-none"
                            viewBox="0 0 20 20"
                            fill="currentColor"
                            aria-hidden="true"
                            data-slot="icon"
                        >
                            <path
                                fill-rule="evenodd"
                                d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z"
                                clip-rule="evenodd"></path>
                        </svg>
                        Custom Design and Development
                    </li>
                    <li class="flex gap-x-3">
                        <svg
                            class="h-6 w-5 flex-none"
                            viewBox="0 0 20 20"
                            fill="currentColor"
                            aria-hidden="true"
                            data-slot="icon"
                        >
                            <path
                                fill-rule="evenodd"
                                d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z"
                                clip-rule="evenodd"></path>
                        </svg>
                        $100 fee per page (after 5)
                    </li>
                    <li class="flex gap-x-3">
                        <svg
                            class="h-6 w-5 flex-none"
                            viewBox="0 0 20 20"
                            fill="currentColor"
                            aria-hidden="true"
                            data-slot="icon"
                        >
                            <path
                                fill-rule="evenodd"
                                d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z"
                                clip-rule="evenodd"></path>
                        </svg>
                        +$50/month Unlimited Edits Add-on
                    </li>
                </ul>
                <a
                    href="contact"
                    aria-describedby="tier-hobby"
                    class="btn btn-outline btn-primary w-full mt-8"
                    >Get started today</a
                >
            </div>
            <div
                class="relative bg-primary rounded-3xl p-8 ring-1 shadow-2xl ring-gray-900/10 sm:p-10"
            >
                <h3
                    id="tier-enterprise"
                    class="text-info-content font-semibold"
                >
                    Monthly
                </h3>
                <p class="mt-4 flex items-baseline gap-x-2">
                    <span
                        class="text-5xl font-semibold tracking-tight text-info-content"
                        >$199</span
                    >
                    <span class="text-info-content">/month</span>
                </p>
                <p class="mt-6 text-info-content">
                    Dedicated support and infrastructure for your company.
                </p>
                <ul
                    role="list"
                    class="mt-8 space-y-3 text-sm/6 sm:mt-10 text-info-content"
                >
                    <li class="flex gap-x-3">
                        <svg
                            class="h-6 w-5 flex-none"
                            viewBox="0 0 20 20"
                            fill="currentColor"
                            aria-hidden="true"
                            data-slot="icon"
                        >
                            <path
                                fill-rule="evenodd"
                                d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z"
                                clip-rule="evenodd"></path>
                        </svg>
                        Includes Hosting
                    </li>
                    <li class="flex gap-x-3">
                        <svg
                            class="h-6 w-5 flex-none"
                            viewBox="0 0 20 20"
                            fill="currentColor"
                            aria-hidden="true"
                            data-slot="icon"
                        >
                            <path
                                fill-rule="evenodd"
                                d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z"
                                clip-rule="evenodd"></path>
                        </svg>
                        Custom Design and Development
                    </li>
                    <li class="flex gap-x-3">
                        <svg
                            class="h-6 w-5 flex-none"
                            viewBox="0 0 20 20"
                            fill="currentColor"
                            aria-hidden="true"
                            data-slot="icon"
                        >
                            <path
                                fill-rule="evenodd"
                                d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z"
                                clip-rule="evenodd"></path>
                        </svg>
                        $100 fee per page (after 5)
                    </li>
                    <li class="flex gap-x-3">
                        <svg
                            class="h-6 w-5 flex-none"
                            viewBox="0 0 20 20"
                            fill="currentColor"
                            aria-hidden="true"
                            data-slot="icon"
                        >
                            <path
                                fill-rule="evenodd"
                                d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z"
                                clip-rule="evenodd"></path>
                        </svg>
                        Unlimited Edits
                    </li>
                    <li class="flex gap-x-3">
                        <svg
                            class="h-6 w-5 flex-none"
                            viewBox="0 0 20 20"
                            fill="currentColor"
                            aria-hidden="true"
                            data-slot="icon"
                        >
                            <path
                                fill-rule="evenodd"
                                d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z"
                                clip-rule="evenodd"></path>
                        </svg>
                        Lifetime Updates
                    </li>
                </ul>
                <a
                    href="contact"
                    aria-describedby="tier-enterprise"
                    class="btn btn-success w-full mt-8">Get started today</a
                >
            </div>
        </div>
    </section>
</MainLayout>
