---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout
    title="Home"
    description="Custom-coded, high-performance websites for local businesses. No bloat, just speed."
>
    <section class="relative isolate px-6 py-24 sm:py-32 lg:px-8">
        <div
            class="absolute inset-x-0 -top-3 -z-10 transform-gpu overflow-hidden px-36 blur-3xl"
            aria-hidden="true"
        >
        </div>
        <div class="mx-auto max-w-4xl text-center">
            <span
                class="rounded-full bg-secondary/10 px-3 py-1 text-sm/6 font-semibold text-primary"
                >Pricing
            </span>
            <h2
                class="mt-6 text-4xl font-semibold tracking-tight text-pretty sm:text-5xl"
            >
                Choose The Right Plan For You
            </h2>
        </div>
        <p
            class="mx-auto mt-6 max-w-2xl text-center text-lg font-medium text-pretty sm:text-xl/8"
        >
            Choose an affordable plan that’s packed with the best features for
            engaging your audience, creating customer loyalty, and driving
            sales.
        </p>
        <div
            class="mx-auto mt-16 grid max-w-lg grid-cols-1 items-center gap-y-6 sm:mt-20 sm:gap-y-0 lg:max-w-4xl lg:grid-cols-2"
        >
            <div
                class="rounded-3xl bg-secondary/10 rounded-t-3xl bg-base-100 p-8 ring-1 ring-gray-900/10 sm:mx-8 sm:rounded-b-none sm:p-10 lg:mx-0 lg:rounded-tr-none lg:rounded-bl-3xl"
            >
                <h3 id="tier-hobby" class="font-semibold">Lump Sum</h3>
                <p class="mt-4 flex items-baseline gap-x-2">
                    <span class="text-5xl font-semibold tracking-tight"
                        >$4,500</span
                    >
                    <span class="text-base">+$25/month for Hosting</span>
                </p>
                <p class="mt-6">
                    Launch your high-performance presence today with one simple,
                    upfront investment.
                </p>
                <ul role="list" class="mt-8 space-y-3 text-sm/6 sm:mt-10">
                    <li class="flex gap-x-3">
                        <svg
                            class="h-6 w-5 flex-none"
                            viewBox="0 0 20 20"
                            fill="currentColor"
                            aria-hidden="true"
                            data-slot="icon"
                        >
                            <path
                                fill-rule="evenodd"
                                d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z"
                                clip-rule="evenodd"></path>
                        </svg>
                        Custom Design and Development
                    </li>
                    <li class="flex gap-x-3">
                        <svg
                            class="h-6 w-5 flex-none"
                            viewBox="0 0 20 20"
                            fill="currentColor"
                            aria-hidden="true"
                            data-slot="icon"
                        >
                            <path
                                fill-rule="evenodd"
                                d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z"
                                clip-rule="evenodd"></path>
                        </svg>
                        $100 fee per page (after 5)
                    </li>
                    <li class="flex gap-x-3">
                        <svg
                            class="h-6 w-5 flex-none"
                            viewBox="0 0 20 20"
                            fill="currentColor"
                            aria-hidden="true"
                            data-slot="icon"
                        >
                            <path
                                fill-rule="evenodd"
                                d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z"
                                clip-rule="evenodd"></path>
                        </svg>
                        +$50/month Unlimited Edits Add-on
                    </li>
                </ul>
                <a
                    href="contact"
                    aria-describedby="tier-hobby"
                    class="btn btn-outline btn-primary w-full mt-8"
                    >Get started today</a
                >
            </div>
            <div
                class="relative bg-primary rounded-3xl p-8 ring-1 shadow-2xl ring-gray-900/10 sm:p-10"
            >
                <h3
                    id="tier-enterprise"
                    class="text-info-content font-semibold"
                >
                    Monthly
                </h3>
                <p class="mt-4 flex items-baseline gap-x-2">
                    <span
                        class="text-5xl font-semibold tracking-tight text-info-content"
                        >$199</span
                    >
                    <span class="text-info-content">/month</span>
                </p>
                <p class="mt-6 text-info-content">
                    Get a premium, managed website with zero upfront costs and
                    unlimited updates.
                </p>
                <ul
                    role="list"
                    class="mt-8 space-y-3 text-sm/6 sm:mt-10 text-info-content"
                >
                    <li class="flex gap-x-3">
                        <svg
                            class="h-6 w-5 flex-none"
                            viewBox="0 0 20 20"
                            fill="currentColor"
                            aria-hidden="true"
                            data-slot="icon"
                        >
                            <path
                                fill-rule="evenodd"
                                d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z"
                                clip-rule="evenodd"></path>
                        </svg>
                        Includes Hosting
                    </li>
                    <li class="flex gap-x-3">
                        <svg
                            class="h-6 w-5 flex-none"
                            viewBox="0 0 20 20"
                            fill="currentColor"
                            aria-hidden="true"
                            data-slot="icon"
                        >
                            <path
                                fill-rule="evenodd"
                                d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z"
                                clip-rule="evenodd"></path>
                        </svg>
                        Custom Design and Development
                    </li>
                    <li class="flex gap-x-3">
                        <svg
                            class="h-6 w-5 flex-none"
                            viewBox="0 0 20 20"
                            fill="currentColor"
                            aria-hidden="true"
                            data-slot="icon"
                        >
                            <path
                                fill-rule="evenodd"
                                d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z"
                                clip-rule="evenodd"></path>
                        </svg>
                        $100 fee per page (after 5)
                    </li>
                    <li class="flex gap-x-3">
                        <svg
                            class="h-6 w-5 flex-none"
                            viewBox="0 0 20 20"
                            fill="currentColor"
                            aria-hidden="true"
                            data-slot="icon"
                        >
                            <path
                                fill-rule="evenodd"
                                d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z"
                                clip-rule="evenodd"></path>
                        </svg>
                        Unlimited Edits
                    </li>
                    <li class="flex gap-x-3">
                        <svg
                            class="h-6 w-5 flex-none"
                            viewBox="0 0 20 20"
                            fill="currentColor"
                            aria-hidden="true"
                            data-slot="icon"
                        >
                            <path
                                fill-rule="evenodd"
                                d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z"
                                clip-rule="evenodd"></path>
                        </svg>
                        Lifetime Updates
                    </li>
                </ul>
                <a
                    href="contact"
                    aria-describedby="tier-enterprise"
                    class="btn btn-success w-full mt-8">Get started today</a
                >
            </div>
        </div>
    </section>
</MainLayout>
