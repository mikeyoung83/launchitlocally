---
import { getCollection, type CollectionEntry } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";
import { Image } from "astro:assets";

// Fetch all entries from the 'portfolio' collection
const projects: CollectionEntry<"portfolio">[] =
    await getCollection("portfolio");

// Sort by date (newest first)
const sortedProjects = projects.sort(
    (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);
---

<MainLayout
    title="Portfolio"
    description="Custom-coded, high-performance websites for local businesses. No bloat, just speed."
>
    <section class="relative isolate px-6 py-24 sm:py-32 lg:px-8">
        <div
            class="absolute inset-x-0 -top-3 -z-10 transform-gpu overflow-hidden px-36 blur-3xl"
            aria-hidden="true"
        >
        </div>
        <div class="mx-auto max-w-4xl">
            <span
                class="rounded-full outline-primary outline-2 px-3 py-1 text-base/6 font-semibold text-primary"
                >Portfolio
            </span>
            <h1
                class="mt-6 text-4xl font-semibold tracking-tight text-pretty sm:text-5xl"
            >
                View Our Latest Work
            </h1>
        </div>
        <p
            class="mx-auto mt-6 max-w-4xl text-lg font-medium text-pretty sm:text-xl/8"
        >
            Choose an affordable plan that’s packed with the best features for
            engaging your audience, creating customer loyalty, and driving
            sales.
        </p>

        <div
            class="grid grid-cols-1 md:grid-cols-2 gap-8 mx-auto mt-16 max-w-lg items-center gap-y-6 sm:mt-20 sm:gap-y-0 lg:max-w-4xl lg:grid-cols-2"
        >
            {
                sortedProjects.map((project) => (
                    <article class="flex flex-col items-start justify-between">
                        <div class="relative w-full">
                            <a href={`/portfolio/${project.slug}`}>
                                <Image
                                    width={500}
                                    height={400}
                                    decoding="async"
                                    loading="eager"
                                    src={project.data.image}
                                    alt={project.data.title}
                                    class="aspect-video w-full rounded-2xl  object-cover sm:aspect-2/1 lg:aspect-3/2"
                                />
                            </a>
                        </div>
                        <div class="max-w-xl">
                            <div class="mt-4 flex items-center gap-x-4 text-xs">
                                <time
                                    datetime="2020-03-16"
                                    class="text-gray-500"
                                >
                                    {project.data.publishDate.toLocaleDateString()}
                                </time>
                            </div>
                            <div class="group relative">
                                <h3 class="mt-3 text-lg/6 font-semibold">
                                    <a href={`/portfolio/${project.slug}`}>
                                        <span class="inset-0" />
                                        {project.data.title}
                                    </a>
                                </h3>
                                <p class="mt-3 line-clamp-3 text-sm/6 ">
                                    {project.data.description}
                                </p>
                            </div>
                        </div>
                    </article>
                ))
            }
        </div>
    </section>
</MainLayout>
